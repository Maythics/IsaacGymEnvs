<?xml version="1.0"?>
<robot name="bottle">
  <!-- Single rigid bottle: meshes derived from DexterousHands bottle_cap asset.
       The original URDF placed the body geometry under a fixed joint with
       rpy="1.5708 0 -1.5708"; we bake that rotation into each visual/collision
       origin and keep the bottle as a single link so the asset has only one
       rigid body (matches the parent task's aggregate-size budget). -->

  <link name="bottle_body">
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-2.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-3.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-4.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-5.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-6.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>
    <visual>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-8.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-2.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-3.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-4.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-5.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-6.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>
    <collision>
      <origin xyz="0 0 0" rpy="1.570796326794897 0 -1.570796326794897"/>
      <geometry>
        <mesh filename="textured_objs/original-8.obj" scale="0.15 0.15 0.15"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.05"/>
      <mass value="0.30"/>
      <inertia ixx="0.0010" iyy="0.0010" izz="0.0004" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>
</robot>
