<?xml version="1.0"?>
<robot name="ycb_peach">
  <link name="ycb_peach">
    <visual>
      <origin xyz="0 0 0"/>
      <geometry>
        <mesh filename="ycb_peach/textured.obj" scale="1 1 1"/>
      </geometry>
    </visual>
    <collision>
      <origin xyz="0 0 0"/>
      <geometry>
        <mesh filename="ycb_peach/collision.ply" scale="1 1 1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.100"/>
      <inertia ixx="3.48e-05" ixy="0" ixz="0" iyy="3.48e-05" iyz="0" izz="3.48e-05"/>
    </inertial>
  </link>
</robot>
